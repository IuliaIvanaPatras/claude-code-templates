{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "SPRING_PROFILES_ACTIVE": "dev"
  },
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(./mvnw *)",
      "Bash(gradle *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(cat build.gradle.kts)",
      "Bash(cat pom.xml)",
      "Bash(cat settings.gradle.kts)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s https://localhost:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)",
      "Read(**/application-prod.yml)",
      "Read(**/application-production.yml)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format.sh",
            "timeout": 30,
            "statusMessage": "Running Checkstyle verification..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh",
            "timeout": 15,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-verification.sh",
            "timeout": 15,
            "statusMessage": "Verifying work before stopping..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-verification.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}